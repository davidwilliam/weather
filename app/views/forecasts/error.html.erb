<% content_for(:title, "Location Not Found") %>
<% content_for(:body_class, "weather-bg theme-overcast") %>

<div class="weather-app">

  <div class="error-page fade-in">
    <div class="error-icon">
      <i class="bi bi-cloud-slash"></i>
    </div>
    <h1 class="error-title">Location Not Found</h1>
    <p class="error-message"><%= @error_message %></p>
  </div>

  <div class="error-search fade-in" style="animation-delay: 0.15s;">
    <p class="error-hint">Try searching with a more specific address, city and state, or zip code.</p>

    <%= form_with url: forecast_path, method: :post, local: true, html: { id: "forecast-form" } do |f| %>
      <div class="search-input-wrap">
        <i class="bi bi-search search-input-icon"></i>
        <%= f.text_field :address,
            value: @address,
            class: "search-input",
            placeholder: "e.g. Colorado Springs, CO 80920",
            required: true,
            autofocus: true,
            autocomplete: "off",
            id: "address" %>
      </div>
      <button type="submit" class="search-btn" id="submit-btn">
        <span id="btn-text">Try Again</span>
        <span id="btn-loading" class="d-none">
          <span class="spinner"></span>
          Searching...
        </span>
      </button>
    <% end %>
  </div>

  <div class="text-center fade-in" style="animation-delay: 0.25s;">
    <%= link_to root_path, class: "back-link" do %>
      <i class="bi bi-arrow-left me-1"></i>Back to search
    <% end %>
  </div>

</div>

<% content_for(:scripts) do %>
  <%= render "forecasts/form_loading" %>
<% end %>
